{
  "name": "vaquill-google-docs-extension",
  "version": "1.0.0",
  "description": "Vaquill Legal AI Contract Copilot for Google Docs - Svelte 5 thin client over the Vaquill API",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:sidebar": "vite build",
    "build:gas": "node scripts/build-gas.js",
    "build:all": "npm run build && npm run build:gas",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "gas:push": "clasp push",
    "gas:pull": "clasp pull",
    "gas:watch": "clasp push --watch",
    "gas:open": "clasp open",
    "gas:deploy": "clasp deploy",
    "gas:login": "clasp login",
    "deploy": "npm run build:all && npm run gas:push",
    "deploy:full": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@lucide/svelte": "^0.563.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.4",
    "@types/google-apps-script": "^1.0.83",
    "@types/node": "^26.1.1",
    "svelte": "^5.26.0",
    "svelte-check": "^4.0.0",
    "terser": "^5.36.0",
    "typescript": "^5.6.0",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
